  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.stratixlite.app",
      "id": "com.stratixlite.app"
    }
  ],

  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "protocol_handlers": [],
  "edge_side_panel": { "preferred_width": 400 }
}
